# AI Academy — optional live-service configuration.
# Everything runs in mock mode with NO variables set. Set ACADEMY_RUNTIME to go live.

# mock (default) | live (direct SDK calls) | maf (Microsoft Agent Framework Agent on Foundry)
ACADEMY_RUNTIME=mock

# Azure OpenAI (Foundry) — used by the chat/polish step of DECIDE
AOAI_ENDPOINT=https://<your-resource>.openai.azure.com
AOAI_KEY=
AOAI_CHAT_DEPLOYMENT=gpt-4.1-mini
AOAI_API_VERSION=2024-10-21

# Azure AI Search — grounded policy retrieval (falls back to the local keyword index)
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=hr-policies

# Azure AI Translator — hr-hrsd-09 multilingual support
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=eastus2

# Azure AI Language — intent classification / PII detection
AZURE_LANGUAGE_ENDPOINT=
AZURE_LANGUAGE_KEY=

# academy-api: require this key in the X-Api-Key header (test-tenant hygiene).
# Empty/unset leaves the API open — mock/dev only.
ACADEMY_API_KEY=

# Point the runtime at a different synthetic-data folder (defaults to <repo>/data)
# ACADEMY_DATA_DIR=
